{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["README.md"],
  "permission": {
    "*": "allow",
    "external_directory": "ask",
    "doom_loop": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "*.pem": "deny",
      "*.key": "deny",
      "*.p12": "deny",
      "*.pfx": "deny",
      "*credentials*": "deny"
    },
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "webfetch": "allow",
    "skill": "allow",
    "task": "ask",
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git branch*": "allow",
      "git rev-parse*": "allow",
      "git remote*": "allow",
      "git ls-files*": "allow",
      "npm run lint*": "allow",
      "npm run typecheck*": "allow",
      "npm run test*": "allow",
      "npm run build*": "allow",
      "npm run format*": "allow",
      "npm run check*": "allow",
      "npm test*": "allow",
      "npx tsc*": "allow",
      "npx vitest*": "allow",
      "npx eslint*": "allow",
      "npx prettier*": "allow",
      "npx tsx scripts/*": "ask",
      "ls*": "allow",
      "pwd": "allow",
      "npm install*": "ask",
      "npm add*": "ask",
      "pnpm install*": "ask",
      "yarn install*": "ask",
      "git add*": "ask",
      "git commit*": "ask",
      "git push*": "ask",
      "git pull*": "ask",
      "git merge*": "ask",
      "git rebase*": "ask",
      "git checkout*": "ask",
      "git switch*": "ask",
      "gh pr create*": "ask",
      "gh issue create*": "ask",
      "rm *": "deny",
      "sudo *": "deny",
      "chmod *": "ask",
      "chown *": "deny",
      "kill *": "ask"
    }
  }
}
